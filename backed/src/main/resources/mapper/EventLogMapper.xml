<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sa.promotion.domain.event.repository.EventLogRepository">

    <resultMap id="EventLogResultMap" type="com.sa.promotion.domain.event.entity.EventLog">
        <id column="event_id" property="eventId"/>
        <result column="event_type" property="eventType"
                javaType="com.sa.promotion.domain.event.enums.EventType"/>
        <result column="promotion_id" property="promotionId"/>
        <result column="prev_activity_status" property="prevActivityStatus"
                javaType="com.sa.promotion.domain.promotion.enums.PromotionStatus"/>
        <result column="prev_audit_status" property="prevAuditStatus"
                javaType="com.sa.promotion.domain.audit.enums.AuditStatus"/>
        <result column="operator" property="operator"/>
        <result column="event_time" property="eventTime"/>
        <result column="params" property="params"/>
    </resultMap>

    <insert id="save">
        INSERT INTO event_log (event_id, event_type, promotion_id, prev_activity_status,
                               prev_audit_status, operator, event_time, params)
        VALUES (#{eventId}, #{eventType, javaType=com.sa.promotion.domain.event.enums.EventType},
                #{promotionId},
                #{prevActivityStatus, javaType=com.sa.promotion.domain.promotion.enums.PromotionStatus},
                #{prevAuditStatus, javaType=com.sa.promotion.domain.audit.enums.AuditStatus},
                #{operator}, #{eventTime}, #{params})
    </insert>

    <select id="findById" resultMap="EventLogResultMap">
        SELECT * FROM event_log WHERE event_id = #{eventId}
    </select>

    <select id="findByPromotionId" resultMap="EventLogResultMap">
        SELECT * FROM event_log WHERE promotion_id = #{promotionId} ORDER BY event_time
    </select>

    <select id="findByEventType" resultMap="EventLogResultMap">
        SELECT * FROM event_log WHERE event_type = #{eventTypeCode} ORDER BY event_time DESC
    </select>

    <select id="findAll" resultMap="EventLogResultMap">
        SELECT * FROM event_log ORDER BY event_time DESC
    </select>

    <delete id="deleteAll">
        DELETE FROM event_log
    </delete>

</mapper>
